<?xml version="1.0" ?>
<!--
  pick_place_scene.world  (v3)
  ============================
  变化说明：
    1. 去掉 sun 和 ground_plane（launch 里已用 empty_world，不重复添加）
    2. 垃圾桶从圆柱体改为空心带底长方体（与实验室实物一致）
    3. 高度层级重新设计，避免物体重叠产生阴影：
         桌面顶面      z = 0.000
         方块底面      z = 0.001（紧贴桌面，重心 z=0.021）
         桶底面        z = 0.001（紧贴桌面，重心 z=0.060）
         桌体本体      pose z = -0.025（桌厚5cm，顶面恰好在 z=0）
    4. 物体实物尺寸（参照 Lab2 图片）：
         方块：5cm × 5cm × 4cm（彩色泡沫/塑料方块）
         垃圾桶：外7cm×7cm×12cm，壁厚+底厚各0.25cm，内空6.5cm×6.5cm×11.75cm
    5. 空心桶用 5 个 box 拼合（底板 + 四面墙）
    6. 桶声明为 static=false，可与方块一样参与随机位置与物理碰撞
    7. 命名约定：{color}_block / {color}_bin
    8. 本文件只包含物体模型，不含 ground/sun/physics 配置

  如何使用：
    把本文件里所有 <model> 标签复制进你现有的 world 文件的 <world> 标签内。
    或者在 launch 文件里把 world 参数指向本文件（已有 empty_world 基础）。
-->
<sdf version="1.6">
<world name="pick_place_world">

  <!-- ════════════════════════════════════════════════════
       工作台
       70cm × 70cm × 5cm，桌面顶面位于 z=0
       pose z=-0.025 使桌体下沿在 z=-0.05
  ════════════════════════════════════════════════════ -->
  <model name="workspace_table">
    <static>true</static>
    <pose>0.28 0.0 -0.025 0 0 0</pose>
    <link name="link">
      <visual name="v">
        <geometry><box><size>0.70 0.70 0.05</size></box></geometry>
        <material>
          <ambient>0.88 0.85 0.78 1</ambient>
          <diffuse>0.88 0.85 0.78 1</diffuse>
          <specular>0.05 0.05 0.05 1</specular>
        </material>
      </visual>
      <collision name="c">
        <geometry><box><size>0.70 0.70 0.05</size></box></geometry>
      </collision>
    </link>
  </model>

  <!-- ════════════════════════════════════════════════════
       彩色方块（5cm × 5cm × 4cm）
       spawn 位置只是初始位置，训练时每 episode 随机传送。
       pose z=0.021 = TABLE_Z(0.001) + BLOCK_H/2(0.02)
  ════════════════════════════════════════════════════ -->

  <model name="red_block">
    <pose>0.18 -0.12 0.021 0 0 0</pose>
    <link name="link">
      <inertial>
        <mass>0.012</mass>
        <inertia><ixx>1.4e-5</ixx><ixy>0</ixy><ixz>0</ixz>
                 <iyy>1.4e-5</iyy><iyz>0</iyz><izz>2.1e-5</izz></inertia>
      </inertial>
      <visual name="v">
        <geometry><box><size>0.05 0.05 0.04</size></box></geometry>
        <material><ambient>0.90 0.10 0.10 1</ambient><diffuse>0.90 0.10 0.10 1</diffuse></material>
      </visual>
      <collision name="c">
        <geometry><box><size>0.05 0.05 0.04</size></box></geometry>
        <surface><friction><ode><mu>0.8</mu><mu2>0.8</mu2></ode></friction></surface>
      </collision>
    </link>
  </model>

  <model name="green_block">
    <pose>0.22 -0.04 0.021 0 0 0</pose>
    <link name="link">
      <inertial><mass>0.012</mass></inertial>
      <visual name="v">
        <geometry><box><size>0.05 0.05 0.04</size></box></geometry>
        <material><ambient>0.10 0.80 0.15 1</ambient><diffuse>0.10 0.80 0.15 1</diffuse></material>
      </visual>
      <collision name="c">
        <geometry><box><size>0.05 0.05 0.04</size></box></geometry>
        <surface><friction><ode><mu>0.8</mu><mu2>0.8</mu2></ode></friction></surface>
      </collision>
    </link>
  </model>

  <model name="blue_block">
    <pose>0.18 0.06 0.021 0 0 0</pose>
    <link name="link">
      <inertial><mass>0.012</mass></inertial>
      <visual name="v">
        <geometry><box><size>0.05 0.05 0.04</size></box></geometry>
        <material><ambient>0.10 0.20 0.90 1</ambient><diffuse>0.10 0.20 0.90 1</diffuse></material>
      </visual>
      <collision name="c">
        <geometry><box><size>0.05 0.05 0.04</size></box></geometry>
        <surface><friction><ode><mu>0.8</mu><mu2>0.8</mu2></ode></friction></surface>
      </collision>
    </link>
  </model>

  <model name="yellow_block">
    <pose>0.24 0.14 0.021 0 0 0</pose>
    <link name="link">
      <inertial><mass>0.012</mass></inertial>
      <visual name="v">
        <geometry><box><size>0.05 0.05 0.04</size></box></geometry>
        <material><ambient>0.95 0.90 0.05 1</ambient><diffuse>0.95 0.90 0.05 1</diffuse></material>
      </visual>
      <collision name="c">
        <geometry><box><size>0.05 0.05 0.04</size></box></geometry>
        <surface><friction><ode><mu>0.8</mu><mu2>0.8</mu2></ode></friction></surface>
      </collision>
    </link>
  </model>

  <model name="pink_block">
    <pose>0.20 -0.16 0.021 0 0 0</pose>
    <link name="link">
      <inertial><mass>0.012</mass></inertial>
      <visual name="v">
        <geometry><box><size>0.05 0.05 0.04</size></box></geometry>
        <material><ambient>0.95 0.40 0.70 1</ambient><diffuse>0.95 0.40 0.70 1</diffuse></material>
      </visual>
      <collision name="c">
        <geometry><box><size>0.05 0.05 0.04</size></box></geometry>
        <surface><friction><ode><mu>0.8</mu><mu2>0.8</mu2></ode></friction></surface>
      </collision>
    </link>
  </model>

  <model name="orange_block">
    <pose>0.26 0.00 0.021 0 0 0</pose>
    <link name="link">
      <inertial><mass>0.012</mass></inertial>
      <visual name="v">
        <geometry><box><size>0.05 0.05 0.04</size></box></geometry>
        <material><ambient>0.95 0.50 0.05 1</ambient><diffuse>0.95 0.50 0.05 1</diffuse></material>
      </visual>
      <collision name="c">
        <geometry><box><size>0.05 0.05 0.04</size></box></geometry>
        <surface><friction><ode><mu>0.8</mu><mu2>0.8</mu2></ode></friction></surface>
      </collision>
    </link>
  </model>

  <!-- ════════════════════════════════════════════════════
       垃圾桶（空心带底长方体）
       外尺寸：7cm × 7cm × 12cm
       壁厚：0.25cm（四面墙）
       底厚：0.25cm
       pose z=0.06 = TABLE_Z(0.0) + BIN_H/2(0.06)

       每个桶由 5 个 link 拼合：
        bottom : 底板  7cm×7cm×0.25cm
        wall_f : 前壁  7cm×0.25cm×11.75cm（贴桶内侧）
         wall_b : 后壁
         wall_l : 左壁
         wall_r : 右壁

       注意：SDF 里同一 model 的 link pose 相对于 model 原点
             model 原点 = 桶的几何中心（x=0,y=0,z=桶高中心）

       桶壁外表面颜色鲜艳，方便 VLM 识别。
       内壁设为同色但深色，增加内外对比。
  ════════════════════════════════════════════════════ -->

  <!-- ─────────── RED BIN ─────────── -->
  <model name="red_bin">
    <static>false</static>
    <!-- spawn位置，训练时会被随机传送 -->
    <pose>0.35 -0.15 0.06 0 0 0</pose>

    <!-- 底板 z_local = -0.06+0.00125 = -0.05875 -->
    <link name="bottom">
      <pose>0 0 -0.05875 0 0 0</pose>
      <visual name="v"><geometry><box><size>0.07 0.07 0.0025</size></box></geometry>
        <material><ambient>0.85 0.08 0.08 1</ambient><diffuse>0.85 0.08 0.08 1</diffuse></material>
      </visual>
      <collision name="c"><geometry><box><size>0.07 0.07 0.0025</size></box></geometry><surface><friction><ode><mu>2.0</mu><mu2>2.0</mu2></ode></friction></surface></collision>
    </link>

    <!-- 前壁 (x+方向) -->
    <link name="wall_f">
      <pose>0.03375 0 0 0 0 0</pose>
      <visual name="v"><geometry><box><size>0.0025 0.07 0.12</size></box></geometry>
        <material><ambient>0.85 0.08 0.08 1</ambient><diffuse>0.85 0.08 0.08 1</diffuse></material>
      </visual>
      <collision name="c"><geometry><box><size>0.0025 0.07 0.12</size></box></geometry></collision>
    </link>

    <!-- 后壁 (x-方向) -->
    <link name="wall_b">
      <pose>-0.03375 0 0 0 0 0</pose>
      <visual name="v"><geometry><box><size>0.0025 0.07 0.12</size></box></geometry>
        <material><ambient>0.85 0.08 0.08 1</ambient><diffuse>0.85 0.08 0.08 1</diffuse></material>
      </visual>
      <collision name="c"><geometry><box><size>0.0025 0.07 0.12</size></box></geometry></collision>
    </link>

    <!-- 左壁 (y+方向) -->
    <link name="wall_l">
      <pose>0 0.03375 0 0 0 0</pose>
      <visual name="v"><geometry><box><size>0.065 0.0025 0.12</size></box></geometry>
        <material><ambient>0.85 0.08 0.08 1</ambient><diffuse>0.85 0.08 0.08 1</diffuse></material>
      </visual>
      <collision name="c"><geometry><box><size>0.065 0.0025 0.12</size></box></geometry></collision>
    </link>

    <!-- 右壁 (y-方向) -->
    <link name="wall_r">
      <pose>0 -0.03375 0 0 0 0</pose>
      <visual name="v"><geometry><box><size>0.065 0.0025 0.12</size></box></geometry>
        <material><ambient>0.85 0.08 0.08 1</ambient><diffuse>0.85 0.08 0.08 1</diffuse></material>
      </visual>
      <collision name="c"><geometry><box><size>0.065 0.0025 0.12</size></box></geometry></collision>
    </link>
  </model>

