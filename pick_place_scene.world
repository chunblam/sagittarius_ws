          <ambient>0.10 0.80 0.15 1</ambient>
          <diffuse>0.12 0.78 0.18 1</diffuse>
          <specular>0.02 0.02 0.02 1</specular>
        </material>
      </visual>
      <collision name="c">
        <geometry><box><size>0.05 0.05 0.05</size></box></geometry>
        <surface><friction><ode><mu>0.75</mu><mu2>0.75</mu2></ode></friction><bounce><restitution_coefficient>0.03</restitution_coefficient><threshold>1e6</threshold></bounce><contact><ode><soft_cfm>0.0025</soft_cfm><soft_erp>0.32</soft_erp><kp>4500</kp><kd>38</kd><max_vel>0.12</max_vel><min_depth>0.002</min_depth></ode></contact></surface>
      </collision>
    </link>
  </model>

  <model name="blue_block">
