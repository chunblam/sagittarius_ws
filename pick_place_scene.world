  <!-- ════════════════════════════════════════════════════
       垃圾桶（空心带底长方体）
       外尺寸：7cm × 7cm × 12cm
       壁厚：0.25cm（四面墙）
       底厚：0.25cm
       pose z=0.06 = TABLE_Z(0.0) + BIN_H/2(0.06)

      每个桶是单 link 整体刚体（5个子碰撞体拼接成空心桶）：
       bottom + wall_f + wall_b + wall_l + wall_r
      各子 visual/collision 的 pose 相对于该单 link 原点；
      model 原点 = 桶的几何中心（x=0,y=0,z=桶高中心）

       桶壁外表面颜色鲜艳，方便 VLM 识别。
       内壁设为同色但深色，增加内外对比。
  ════════════════════════════════════════════════════ -->
  <!-- ─────────── RED BIN ─────────── -->
  <model name="red_bin">
    <static>false</static>
    <pose>0.35 -0.15 0.06 0 0 0</pose>
    <link name="link">
      <inertial>
        <mass>0.22</mass>
        <inertia><ixx>2.48e-4</ixx><ixy>0</ixy><ixz>0</ixz><iyy>2.48e-4</iyy><iyz>0</iyz><izz>3.58e-4</izz></inertia>
      </inertial>
      <visual name="bottom_v"><pose>0 0 -0.05875 0 0 0</pose><geometry><box><size>0.07 0.07 0.0025</size></box></geometry><material><ambient>0.85 0.08 0.08 1</ambient><diffuse>0.85 0.08 0.08 1</diffuse></material></visual>
      <visual name="wall_f_v"><pose>0.03375 0 0 0 0 0</pose><geometry><box><size>0.0025 0.07 0.12</size></box></geometry><material><ambient>0.85 0.08 0.08 1</ambient><diffuse>0.85 0.08 0.08 1</diffuse></material></visual>
      <visual name="wall_b_v"><pose>-0.03375 0 0 0 0 0</pose><geometry><box><size>0.0025 0.07 0.12</size></box></geometry><material><ambient>0.85 0.08 0.08 1</ambient><diffuse>0.85 0.08 0.08 1</diffuse></material></visual>
      <visual name="wall_l_v"><pose>0 0.03375 0 0 0 0</pose><geometry><box><size>0.065 0.0025 0.12</size></box></geometry><material><ambient>0.85 0.08 0.08 1</ambient><diffuse>0.85 0.08 0.08 1</diffuse></material></visual>
      <visual name="wall_r_v"><pose>0 -0.03375 0 0 0 0</pose><geometry><box><size>0.065 0.0025 0.12</size></box></geometry><material><ambient>0.85 0.08 0.08 1</ambient><diffuse>0.85 0.08 0.08 1</diffuse></material></visual>

      <collision name="bottom_c"><pose>0 0 -0.05875 0 0 0</pose><geometry><box><size>0.07 0.07 0.0025</size></box></geometry><surface><friction><ode><mu>2.0</mu><mu2>2.0</mu2></ode></friction></surface></collision>
      <collision name="wall_f_c"><pose>0.03375 0 0 0 0 0</pose><geometry><box><size>0.0025 0.07 0.12</size></box></geometry></collision>
      <collision name="wall_b_c"><pose>-0.03375 0 0 0 0 0</pose><geometry><box><size>0.0025 0.07 0.12</size></box></geometry></collision>
      <collision name="wall_l_c"><pose>0 0.03375 0 0 0 0</pose><geometry><box><size>0.065 0.0025 0.12</size></box></geometry></collision>
      <collision name="wall_r_c"><pose>0 -0.03375 0 0 0 0</pose><geometry><box><size>0.065 0.0025 0.12</size></box></geometry></collision>
    </link>
  </model>

